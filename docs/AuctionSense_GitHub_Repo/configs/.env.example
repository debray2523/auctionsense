# AuctionSense — Environment Configuration
# Copy this file to configs/.env and fill in your credentials

# ── OpenAI / Azure OpenAI ──────────────────────────────────────
# Option A: Standard OpenAI
OPENAI_API_KEY=sk-...

# Option B: Azure OpenAI (takes precedence if AZURE_OPENAI_ENDPOINT is set)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-05-01-preview
# AZURE_OPENAI_API_KEY=your-azure-key

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://auctionsense:auctionsense@localhost:5432/auctionsense

# ── MLflow ────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Commodity API (optional — falls back to yfinance defaults) ─
# MCX_API_KEY=your-mcx-api-key
# LME_API_KEY=your-lme-api-key

# ── Application ────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
THIN_PARTICIPATION_THRESHOLD=4
MAX_BRIEFING_LATENCY_SECONDS=60
